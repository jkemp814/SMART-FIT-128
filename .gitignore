# Ignore Python virtual environments and caches
**/.venv/
**/__pycache__/
**/.mypy_cache/
**/.pytest_cache/

# macOS system files
**/.DS_Store

# Node.js dependencies
**/node_modules/

# Environment and secrets
**/.env

# VS Code workspace settings
.vscode/

# Ignore Docker build output and workspace folders
workspace/

# Ignore project-specific generated files
projects/*/node_modules/
projects/*/.venv/
projects/*/__pycache__/

# Ignore log files
*.log

# Ignore compiled binaries
*.o
*.so
*.exe
*.dll
*.pyc
*.pyo

# Ignore coverage reports
htmlcov/
.coverage

# Ignore all development environments and devcontainers
Environments/

# Ignore VS Code Portable Linux
VSCodePortable-Linux/
VSCodePortable-Windows/
Toolchest/Fonts/
coverage.xml

# Ignore temporary files
*.swp
*.swo
*~

# Ignore backup files
*.bak
*.tmp

# Ignore system files
.uuid
Thumbs.db
.Trash-1000
Desktop.ini
.goutputstream-*
System Volume Information

# Ignore PortableApps
PortableApps
PortableGit
